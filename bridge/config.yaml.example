# bayrol-bridge Konfiguration
# Kopieren nach config.yaml und anpassen

bayrol_broker:
  host: localhost        # Mosquitto läuft im selben Container
  port: 1883
  serial: "23ASE2-06017"

ha_broker:
  host: 192.168.1.x     # HA-Host IP
  port: 1883
  username: mqttuser
  password: mqttha

output_prefix: bayrol/pool
# Resultierende Topics: bayrol/pool/redox, bayrol/pool/ph, etc.
