# bayrol-bridge configuration
# Copy to config.yaml and adjust

bayrol_broker:
  host: localhost        # Mosquitto runs in the same container
  port: 1883
  serial: "23XXX-XXXXX" # printed on device, format: 23ASE2-XXXXX

ha_broker:
  host: 192.168.1.x     # HA host IP
  port: 1883
  username: mqttuser
  password: your-mqtt-password

output_prefix: bayrol/pool
# Resulting topics: bayrol/pool/redox, bayrol/pool/ph, etc.

# discovery_prefix: homeassistant
# HA MQTT Autodiscovery prefix (default: homeassistant)

web:
  port: 8080
  # Web UI port (default: 8080)
